      "type": "text",
      "x": 606.6666666666667,
      "y": -202.5000000000001,
      "width": 1601.7581787109375,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aN",
      "roundness": null,
      "seed": 1879703297,
      "version": 335,
      "versionNonce": 1876609811,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773461314594,
      "link": null,
      "locked": false,
      "text": "Dropbox is a cloud-based file storage serice that allows users to store and share files. It provides a secure and reliable way to store and access files from anywhere, on any device",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Dropbox is a cloud-based file storage serice that allows users to store and share files. It provides a secure and reliable way to store and access files from anywhere, on any device",
      "autoResize": true,
      "lineHeight": 1.25
    },
