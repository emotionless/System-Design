    {
      "id": "SfhS3CPW1x_TwHsqNw4T3",
      "type": "text",
      "x": 510.71428571428584,
      "y": 816.3095238095236,
      "width": 532.49951171875,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "dashed",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aT",
      "roundness": null,
      "seed": 70542049,
      "version": 410,
      "versionNonce": 390413747,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773461531311,
      "link": null,
      "locked": false,
      "text": "or Quality Requirement of the System\n\n- availability >> consistency\n- low latency on upload and download (as low as possible)\n- support large files as 50gb\n    - resumable uploads\n- high data integrity (sync accuracy)",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "or Quality Requirement of the System\n\n- availability >> consistency\n- low latency on upload and download (as low as possible)\n- support large files as 50gb\n    - resumable uploads\n- high data integrity (sync accuracy)",
      "autoResize": true,
      "lineHeight": 1.25
    },
