      "updated": 1773669818902,
      "link": null,
      "locked": false,
      "text": "// *One to one mapping for our FC\n\nPOST /fiels -> presigned url\nbody: FileMetadata\n\nPUT {presigned url}\nbody: FileChunk\n\nPATCH /files -> 200\nBody: Partial <FileMetadata> (chunk status updates)\n\nGET /files/:fileId -> File&FileMetadata\n\nGET /changes?since={timestamp} -> fileMetaData[]",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "// *One to one mapping for our FC\n\nPOST /fiels -> presigned url\nbody: FileMetadata\n\nPUT {presigned url}\nbody: FileChunk\n\nPATCH /files -> 200\nBody: Partial <FileMetadata> (chunk status updates)\n\nGET /files/:fileId -> File&FileMetadata\n\nGET /changes?since={timestamp} -> fileMetaData[]",
      "autoResize": true,
      "lineHeight": 1.25
    },
