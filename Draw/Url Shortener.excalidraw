    {
      "id": "52w40KwB4MlZGcehLqKYr",
      "type": "text",
      "x": 606.6666666666667,
      "y": -202.5000000000001,
      "width": 1313.5184326171875,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aN",
      "roundness": null,
      "seed": 1879703297,
      "version": 154,
      "versionNonce": 1297625025,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772862589584,
      "link": null,
      "locked": false,
      "text": "Bit.ly is a URL shortening service that converts long URLs into shorter, manageable links. ie. www.mylongurl.com/long/is/annoying -> www.bit.ly/",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Bit.ly is a URL shortening service that converts long URLs into shorter, manageable links. ie. www.mylongurl.com/long/is/annoying -> www.bit.ly/",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
