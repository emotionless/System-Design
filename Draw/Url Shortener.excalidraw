    {
      "id": "SfhS3CPW1x_TwHsqNw4T3",
      "type": "text",
      "x": 510.71428571428584,
      "y": 816.3095238095236,
      "width": 519.2594604492188,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
