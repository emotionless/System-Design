      "isDeleted": false,
      "boundElements": null,
      "updated": 1772865708751,
      "link": null,
      "locked": false,
      "text": "Back of the Envelop (BOTE) Estimation:",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Back of the Envelop (BOTE) Estimation:",
