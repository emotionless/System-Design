    {
      "id": "MDhPs4YVQX2wihMkk3C2T",
      "type": "text",
      "x": 601.6666666666667,
      "y": -271.38888888888897,
      "width": 400.716064453125,
      "height": 45,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aM",
      "roundness": null,
      "seed": 537979183,
      "version": 77,
      "versionNonce": 549216577,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772863002052,
      "link": null,
      "locked": false,
      "text": "URL Shortener like Bit.ly",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "URL Shortener like Bit.ly",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "52w40KwB4MlZGcehLqKYr",
      "type": "text",
      "x": 606.6666666666667,
      "y": -202.5000000000001,
      "width": 1313.5184326171875,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aN",
      "roundness": null,
      "seed": 1879703297,
      "version": 154,
      "versionNonce": 1297625025,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772862589584,
      "link": null,
      "locked": false,
      "text": "Bit.ly is a URL shortening service that converts long URLs into shorter, manageable links. ie. www.mylongurl.com/long/is/annoying -> www.bit.ly/",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Bit.ly is a URL shortening service that converts long URLs into shorter, manageable links. ie. www.mylongurl.com/long/is/annoying -> www.bit.ly/",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "dWbuzoa-9ysDm6Rm1iuuJ",
      "type": "text",
      "x": 496.6666666666667,
      "y": 515.8333333333333,
      "width": 413.6041259765625,
      "height": 45,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "dashed",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aO",
      "roundness": null,
      "seed": 641316417,
      "version": 50,
      "versionNonce": 1426899041,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772863113795,
      "link": null,
      "locked": false,
      "text": "Functional Requirements:",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Functional Requirements:",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "dVpEjx1Vi2Es8HpC_ZeiC",
      "type": "text",
      "x": 503.0952380952381,
      "y": 577.2619047619047,
      "width": 474.339599609375,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "dashed",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aP",
      "roundness": null,
      "seed": 784379905,
      "version": 237,
      "versionNonce": 1818416321,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772863294335,
      "link": null,
      "locked": false,
      "text": "- Create a short url from a long url\n    - Optionally support custom alias\n    - Optionally support an expiration time\n- Be redirected to the original URL from the short url",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- Create a short url from a long url\n    - Optionally support custom alias\n    - Optionally support an expiration time\n- Be redirected to the original URL from the short url",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "qH1mNPFpV1buEqgnnMfHh",
      "type": "text",
      "x": 500.71428571428584,
      "y": 767.7380952380951,
      "width": 489.24017333984375,
      "height": 45,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "dashed",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aQ",
      "roundness": null,
      "seed": 117828673,
      "version": 133,
      "versionNonce": 1147971905,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772863447434,
      "link": null,
      "locked": false,
      "text": "Non-functional Requirements:",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Non-functional Requirements:",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "SfhS3CPW1x_TwHsqNw4T3",
      "type": "text",
      "x": 510.71428571428584,
      "y": 816.3095238095236,
      "width": 519.2594604492188,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "dashed",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aT",
      "roundness": null,
      "seed": 70542049,
      "version": 215,
      "versionNonce": 492516737,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772865287631,
      "link": null,
      "locked": false,
      "text": "or Quality Requirement of the System\n\n- Low latency on redirects (~200ms)\n- Scale to support 100M DAU and 1B urls\n- Ensure uniqueness of the short code\n- High availability, eventual consistency for url shortening",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "or Quality Requirement of the System\n\n- Low latency on redirects (~200ms)\n- Scale to support 100M DAU and 1B urls\n- Ensure uniqueness of the short code\n- High availability, eventual consistency for url shortening",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "OGUUNaVIKWn63avoIEIrX",
      "type": "text",
      "x": 519.2857142857147,
      "y": 1073.4523809523812,
      "width": 639.8282470703125,
      "height": 45,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
