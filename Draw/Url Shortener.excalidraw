    },
    {
      "id": "EIq1DcXyzHlUT8Jr5oS6-",
      "type": "text",
      "x": 523.5714285714287,
      "y": 1129.1666666666665,
      "width": 180.7998046875,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "dashed",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aW",
      "roundness": null,
      "seed": 1852431055,
      "version": 68,
      "versionNonce": 1871359297,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772865538486,
      "link": null,
      "locked": false,
      "text": "- Scale\n- Storage\n- Latency\n- DAU\n- Yearly active users",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- Scale\n- Storage\n- Latency\n- DAU\n- Yearly active users",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "f8LhJmmGYVz1dGar3m5AY",
      "type": "text",
      "x": 1214.9999999999998,
      "y": 823.4523809523808,
      "width": 434.7995300292969,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
