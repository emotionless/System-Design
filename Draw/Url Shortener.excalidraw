      "type": "text",
      "x": 503.0952380952381,
      "y": 577.2619047619047,
      "width": 474.339599609375,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "dashed",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aP",
      "roundness": null,
      "seed": 784379905,
      "version": 237,
      "versionNonce": 1818416321,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772863294335,
      "link": null,
      "locked": false,
      "text": "- Create a short url from a long url\n    - Optionally support custom alias\n    - Optionally support an expiration time\n- Be redirected to the original URL from the short url",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- Create a short url from a long url\n    - Optionally support custom alias\n    - Optionally support an expiration time\n- Be redirected to the original URL from the short url",
